rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // HELPER: Check if request is from the authenticated admin
    function isAdmin() {
      return request.auth != null && (
        request.auth.uid == 'rZaL1kVALOMewoZcjIePDAyXKji2' ||
        request.auth.uid == '3xyxYBDNsnermsXQeqWpVen0adE3' ||
        request.auth.token.email == 'mwijaydavie@gmail.com' ||
        request.auth.token.email == 'theglorifiedkeys@gmail.com' ||
        request.auth.token.role == 'admin' ||
        request.auth.token.role == 'owner' ||
        request.auth.token.admin == true ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner')) ||
        (exists(/databases/$(database)/documents/clients/$(request.auth.uid)) && 
         (get(/databases/$(database)/documents/clients/$(request.auth.uid)).data.role == 'admin' || 
          get(/databases/$(database)/documents/clients/$(request.auth.uid)).data.role == 'owner'))
      );
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    // Public collections (Read-only for everyone)
    match /announcements/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /logos/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /projects/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /blogs/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /products/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /site_config/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /testimonials/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /packages/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /services/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /team_members/{docId} { allow read: if true; allow write: if isAdmin(); }

    // Agreements (Create-only for everyone, Read/Write for Admin)
    match /agreements/{agreementId} {
      allow create: if true;
      allow read, list, update, delete: if isAdmin();
    }

    // Forms (Create-only for everyone)
    match /subscribers/{docId} { allow create: if true; allow read: if isAdmin(); }
    match /analytics_events/{docId} { allow create: if true; allow read: if isAdmin(); }
    match /inquiries/{docId} { allow create: if true; allow read: if isAdmin(); }
    match /project_inquiries/{docId} { allow create: if true; allow read: if isAdmin(); }

    // Clients Collection
    match /clients/{uid} {
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == uid);
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if isAdmin() || (request.auth != null && request.auth.uid == uid);
      allow delete: if isAdmin();
    }

    // Client Projects & Messages
    match /client_projects/{docId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.clientId == request.auth.uid);
      allow write: if isAdmin();
    }
    match /client_messages/{projectId}/messages/{msgId} {
      allow read: if isAdmin() || (request.auth != null && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId));
      allow create: if request.auth != null;
      allow update: if isAdmin();
    }

    // Orders Registry - GUEST ACCESSIBLE VIA ID
    match /orders/{orderId} {
      allow create: if true;
      // Allow specific GET if doc ID matches orderId (provided by client)
      allow get: if true; 
      // Allow protected LIST for owners and admin
      allow list: if isAdmin() || (request.auth != null && (resource.data.uid == request.auth.uid || resource.data.customerEmail == request.auth.token.email));
      allow update, delete: if isAdmin();
    }
    
    match /access_tokens/{docId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.uid == request.auth.uid);
      allow write: if isAdmin();
    }

    // User Profile Node & Subcollections
    match /users/{userId} {
      allow read: if true;
      allow write: if isAdmin();
      
      match /socialLinks/{docId} { allow read: if true; allow write: if isAdmin(); }
      match /projects/{docId} { allow read: if true; allow write: if isAdmin(); }
      match /experienceItems/{docId} { allow read: if true; allow write: if isAdmin(); }
      match /recognitions/{docId} { allow read: if true; allow write: if isAdmin(); }
      match /skills/{docId} { allow read: if true; allow write: if isAdmin(); }
      match /services/{docId} { allow read: if true; allow write: if isAdmin(); }
    }

    // Rate Limiting (Public Write, Admin Read)
    match /rate_limits/{docId} {
      allow read: if isAdmin();
      allow write: if true;
    }

    // Global Catch-all (Secure by default)
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}